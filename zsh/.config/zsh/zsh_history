#include "exposure_control/exposure_control_node.hpp"\
\
#include <chrono>\
#include <rclcpp/logging.hpp>\
#include <string>\
#include <thread>\
\
namespace exposure_control\
{\
using std::placeholders::_1;\
\
ExposureControlNode::ExposureControlNode(const rclcpp::NodeOptions & options)\
: Node("exposure_control", options),\
  timer_duration_(3.0),\
  cooldown_time_(15.0),\
  time_Ae_(3.0),\
  offset_exposure_(0.2),\
  distance_threshold_(0.1),\
  exposure_max_(10000),\
  exposure_index_(-1),\
  initialized_(false),\
  etm_manual_(true)\
{\
  get_params();\
\
  std::chrono::duration<float> d(timer_duration_);\
  timer_ = create_wall_timer(d, std::bind(&ExposureControlNode::on_timer, this));\
\
  service_name_ = "/camera_ros/set_parameters";\
\
  auto client_cb_group_ = this->create_callback_group(rclcpp::CallbackGroupType::Reentrant);\
\
  param_client_ = this->create_client<SetParameters>(\
    service_name_, rclcpp::QoS(rclcpp::KeepLast(10)), client_cb_group_);\
\
  diag_subscription_ = create_subscription<diagnostic_msgs::msg::DiagnosticArray>(\
    "/diagnostics", 10, std::bind(&ExposureControlNode::diagnostics_callback, this, _1));\
  odom_subscription_ = create_subscription<nav_msgs::msg::Odometry>(\
    "/odom", 10, std::bind(&ExposureControlNode::odom_callback, this, _1));\
\
  RCLCPP_INFO_STREAM(this->get_logger(), "Init Done !");\
}\
\
void ExposureControlNode::get_params()\
{\
  get_param("time_stationary", timer_duration_);\
  get_param("cooldown_time", cooldown_time_);\
  get_param("time_Ae", time_Ae_);\
  get_param("offset_exposure", offset_exposure_);\
  get_param("distance_threshold", distance_threshold_);\
  get_param("exposure_max", exposure_max_);\
}\
\
void ExposureControlNode::on_timer()\
{\
  RCLCPP_INFO_STREAM(\
    this->get_logger(), "No movement for " << timer_duration_ << "seconds. Auto-exposure ON.");\
\
  set_exposure_time_mode(EXPOSURE_TIME_MODE::AUTO);\
  etm_manual_ = false;\
\
  rclcpp::sleep_for(std::chrono::milliseconds(int(time_Ae_ * 1000)));\
\
  int effective_ET = std::min(\
    static_cast<int>(std::floor((1 + offset_exposure_) * curr_exposure_time_)), exposure_max_);\
\
  set_exposure_time_mode(EXPOSURE_TIME_MODE::MANUAL);\
\
  while (!etm_manual_) {\
    rclcpp::sleep_for(std::chrono::milliseconds(10));\
  }\
  set_exposure_time(effective_ET);\
  RCLCPP_INFO_STREAM(this->get_logger(), "Auto-exposure OFF.");\
\
  rclcpp::sleep_for(std::chrono::milliseconds(int(cooldown_time_ * 1000)));\
  timer_->reset();\
}\
\
void ExposureControlNode::diagnostics_callback(\
  const diagnostic_msgs::msg::DiagnosticArray::SharedPtr msg)\
{\
  try {\
    if (msg->status.empty()) {\
      return;\
    }\
    auto status = msg->status[0];\
    if (exposure_index_ < 0) {\
      for (std::size_t i = 0; i < std::size(status.values); ++i) {\
        if (status.values[i].key == "ExposureTime") {\
          exposure_index_ = i;\
        }\
      }\
    }\
\
    if (exposure_index_ < 0) {\
      return;\
    }\
    curr_exposure_time_ = std::stof(status.values[exposure_index_].value);\
  } catch (const std::exception & e) {\
    RCLCPP_ERROR(this->get_logger(), "Can't get exposure value : %s", e.what());\
  }\
}\
\
void ExposureControlNode::odom_callback(const nav_msgs::msg::Odometry::SharedPtr msg)\
{\
  if (!initialized_) {\
    last_position_ = msg->pose.pose.position;\
    last_orientation_ = msg->pose.pose.orientation;\
    RCLCPP_INFO_STREAM(this->get_logger(), "Starting pose set" << std::endl);\
    initialized_ = true;\
  }\
\
  geometry_msgs::msg::Point position = msg->pose.pose.position;\
  geometry_msgs::msg::Quaternion orientation = msg->pose.pose.orientation;\
\
  float dist = std::sqrt(\
    (position.z - last_position_.z) * (position.z - last_position_.z) +\
    (position.y - last_position_.y) * (position.y - last_position_.y) +\
    (position.x - last_position_.x) * (position.x - last_position_.x));\
\
  if (dist > distance_threshold_) {\
    last_position_ = position;\
    last_orientation_ = orientation;\
    timer_->reset();\
  }\
}\
\
void ExposureControlNode::set_exposure_time(const int value)\
{\
  auto parameter = rcl_interfaces::msg::Parameter();\
  auto request = std::make_shared<SetParameters::Request>();\
\
  parameter.name = "ExposureTime";  // E.g.: parameter_name = "background_b"\
  parameter.value.type = 2;         //  bool = 1,    int = 2,        float = 3,     string = 4\
  parameter.value.integer_value =\
    value;  // .bool_value, .integer_value, .double_value, .string_value\
\
  request->parameters.push_back(parameter);\
\
  while (!param_client_->wait_for_service(std::chrono::seconds(1))) {\
    RCLCPP_WARN_STREAM(\
      this->get_logger(), "service " << service_name_ << " not available, waiting again...");\
  }\
\
  auto result = param_client_->async_send_request(\
    request, [this, value](rclcpp::Client<SetParameters>::SharedFuture future) {\
      auto response = future.get();\
\
      auto result = response->results[0];\
      if (result.successful) {\
        RCLCPP_INFO_STREAM(this->get_logger(), "Parameter ExposureTime set to " << value);\
      } else {\
        RCLCPP_WARN_STREAM(\
          this->get_logger(), "Failed to set parameter ExposureTime : " << result.reason.c_str());\
      }\
    });\
}\
\
void ExposureControlNode::set_exposure_time_mode(const int value)\
{\
  etm_response_ = false;\
  auto parameter = rcl_interfaces::msg::Parameter();\
  auto request = std::make_shared<SetParameters::Request>();\
\
  parameter.name = "ExposureTimeMode";  // E.g.: parameter_name = "background_b"\
  parameter.value.type = 2;             //  bool = 1,    int = 2,        float = 3,     string = 4\
  parameter.value.integer_value =\
    value;  // .bool_value, .integer_value, .double_value, .string_value\
\
  request->parameters.push_back(parameter);\
  RCLCPP_WARN_STREAM(this->get_logger(), "PARAM PUSHED BACK");\
\
  while (!param_client_->wait_for_service(std::chrono::seconds(1))) {\
    RCLCPP_WARN_STREAM(\
