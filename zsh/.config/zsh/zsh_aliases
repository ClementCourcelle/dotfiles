cd() {
    # requires fd and fzf
    if [[ $# -eq 0 ]]; then
       # reproduce the behavior of `cd` with no arguments
       builtin cd
    elif [[ $1 == "-" ]]; then
       builtin cd - || exit
    elif [[ -d "$1" ]]; then
       # if the folder exists, go there
       builtin cd "$1" || exit
    else
       # finally, look for alternatives with fzf based on user input
		# local sess_root=$(tmux show-environment SESS_ROOT | cut -d= -f2-)
		local search_paths=(
           "."                 
			"$SESS_ROOT"
       )
       # builtin cd "$( fd --type directory "${search_paths[@]}" | \
       # fzf +m --preview-window=right:60%:wrap --preview 'tree -C {} | head -200' \
       # --query "$1" )" || exit
       builtin cd "$( fd --type directory "${search_paths[@]}" | \
       fzf +m --query "$1" )" || exit
    fi
}

function cdr(){
  if [[ -n $TMUX ]]; then
    # local sess_root=$(tmux show-environment SESS_ROOT | cut -d= -f2-)
    cd $SESS_ROOT
  else
    cd $HOME
  fi
}

function dus() {
  du -hs --time "$1"* | sort -h
}
function dut() {
  du -hs --time "$1"* | sort -k 2
}

function sros() {
  source /opt/ros/humble/setup.zsh
  source /usr/share/gazebo/setup.sh
  if [[ -f ./install/local_setup.zsh ]]; then
    source ./install/local_setup.zsh
  elif [[ -n $TMUX && -f $SESS_ROOT/install/local_setup.zsh ]]; then
    source $SESS_ROOT/install/local_setup.zsh
  fi
  source /opt/ros/$ROS_DISTRO/share/ros2cli/environment/ros2-argcomplete.zsh
  export ROS_AUTOMATIC_DISCOVERY_RANGE=LOCALHOST
  #export RMW_IMPLEMENTATION=rmw_fastrtps_cpp
  export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
  export CYCLONEDDS_URI="<CycloneDDS><Domain>
  <General><Interfaces><NetworkInterface name=\"lo\"/></Interfaces><AllowMulticast>true</AllowMulticast></General>
  <Discovery><ParticipantIndex>none</ParticipantIndex></Discovery>
  </Domain></CycloneDDS>
  <Gen><Allow>spdp</Allow></Gen>"
}

function async_sros() {
  {
    sros
    export -p > "$1"
    touch "$2"
  } >/dev/null 2>&1 &
}


function mkcd {
  last=$(eval "echo \$$#")
  if [ ! -n "$last" ]; then
    echo "Enter a directory name"
  elif [ -d $last ]; then
    echo "\`$last' already exists"
  else
    mkdir $@ && cd $last
  fi
}

function install_devcontainer {
  bash $HOME/projects/devcontainer_template/install_dev.sh "$@"
  docker compose -f .devcontainer/compose.yaml build nvim
  docker compose -f .devcontainer/compose.yaml run --rm compile
}

function dev {
  if [[ -f "./.devcontainer/compose.yaml" ]]; then
    docker compose -f .devcontainer/compose.yaml run --rm nvim
  else
    echo "No devcontainer"
  fi
}
